# Copy this file to `.env` and fill in the values you plan to use.
# Anything left blank simply falls back to the default shown in the comment.

# ---------- GitHub API (used by mcp_server.py) ----------
# Optional. Without it, the live GitHub API limits you to 60 requests/hour.
# With it, the limit is raised to 5,000 requests/hour.
# Generate a free token at https://github.com/settings/tokens
# GITHUB_TOKEN=

# ---------- LLM backend (used by model_client.py) ----------
# Defaults to "ollama" when GROQ_API_KEY is unset, otherwise "groq".
# Force a specific backend by setting this explicitly.
# LLM_BACKEND=ollama

# ---------- Ollama (local) ----------
# Only needed if LLM_BACKEND=ollama.
# Pull the model first:  ollama pull qwen2.5:3b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:3b

# ---------- Groq (cloud) ----------
# Only needed if LLM_BACKEND=groq.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
